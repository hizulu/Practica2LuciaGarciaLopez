<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Practica2LuciaGarciaLopez.Configuracion"
             Title="Configuracion"
             Padding="0,50,0,0">
    
    <VerticalStackLayout Padding="20" Spacing="25">

        <Label Text="PERSONALIZACIÓN" 
               TextColor="{StaticResource Gray500}" 
               FontSize="14" CharacterSpacing="2" />

        <Border StrokeShape="RoundRectangle 15" 
                Padding="20" 
                StrokeThickness="0">
            
            <!--Modo oscuro-->
            <VerticalStackLayout Spacing="20">
                <Grid ColumnDefinitions="*, Auto">
                    <Label Text="Modo Oscuro" 
                           VerticalOptions="Center" />
                    <Switch x:Name="themeSwitch" 
                            Toggled="OnThemeToggled" 
                            Grid.Column="1" />
                </Grid>

                <BoxView HeightRequest="1" Color="{StaticResource Gray100}" />

                <!--Cambio de fuente-->
                <VerticalStackLayout Spacing="10">
                    <Label Text="Fuente del Sistema" />
                    <Picker x:Name="fontPicker" 
                            SelectedIndexChanged="OnFontChanged">
                        <Picker.ItemsSource>
                            <x:Array Type="{x:Type x:String}">
                                <x:String>AlteHaasGroteskRegular</x:String>
                                <x:String>ButlerFreeMed</x:String>
                                <x:String>OpenSansRegular</x:String>
                            </x:Array>
                        </Picker.ItemsSource>
                    </Picker>
                </VerticalStackLayout>

                <BoxView HeightRequest="1" Color="{StaticResource Gray100}" />

                <!--Cambio del tamaño de letra-->
                <VerticalStackLayout Spacing="10">
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="Tamaño de letra:" />
                        <Label Text="{Binding Source={x:Reference sizeSlider}, 
                               Path=Value, 
                               StringFormat='{0:F0}'}" 
                               FontAttributes="Bold" />
                    </HorizontalStackLayout>
                    <Slider x:Name="sizeSlider" 
                            Minimum="12" 
                            Maximum="30" 
                            ValueChanged="OnSizeChanged" />
                </VerticalStackLayout>
            </VerticalStackLayout>
        </Border>
    </VerticalStackLayout>
</ContentPage>