<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Practica2LuciaGarciaLopez"
             x:Class="Practica2LuciaGarciaLopez.App">
    <Application.Resources>
        <ResourceDictionary>

             <!--COLOR GLOBAL DEL TEXTO--> 
            <!--<Color x:Key="TextoColor">#000000</Color>-->

             <!--TAMAÑO GLOBAL DEL TEXTO--> 
            <x:Double x:Key="TextoSize">18</x:Double>

            <!-- FUENTE GLOBAL -->
            <OnPlatform x:Key="customFont" x:TypeArguments="x:String">
                <On Platform="Android" Value="AlteHaasGroteskRegular.ttf#AlteHaasGroteskRegular" />
                <On Platform="iOS" Value="AlteHaasGroteskRegular.ttf#AlteHaasGroteskRegular" />
                <On Platform="WinUI" Value="Assets/Fonts/AlteHaasGroteskRegular.ttf#AlteHaasGroteskRegular" />
            </OnPlatform>

            <!-- ESTILO GLOBAL PARA LABEL -->
            <Style TargetType="Label">
                <Setter Property="TextColor" Value="{DynamicResource TextoColor}" />
                <Setter Property="FontSize" Value="{DynamicResource TextoSize}" />
                <Setter Property="FontFamily" Value="{DynamicResource customFont}" />
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
