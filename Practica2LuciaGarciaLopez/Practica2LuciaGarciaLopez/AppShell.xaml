<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Practica2LuciaGarciaLopez.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Practica2LuciaGarciaLopez"
    Shell.FlyoutBehavior="Disabled"
    Title="Practica2LuciaGarciaLopez">

    <FlyoutItem
    Title="Home">
        <ShellContent
       Title="Home"
       ContentTemplate="{DataTemplate local:MainPage}"
       Route="MainPage" />
    </FlyoutItem>

    <FlyoutItem
    Title="Galeria">
        <ShellContent
       Title="Galería"
       ContentTemplate="{DataTemplate local:Galeria}"
       Route="Galeria" />
    </FlyoutItem>

    <FlyoutItem
    Title="Configuracion">
        <ShellContent
       Title="Configuración"
       ContentTemplate="{DataTemplate local:Configuracion}"
       Route="Configuracion" />
    </FlyoutItem>

</Shell>
